Name) {\n\t\t\t\tctx.ui.notify(\"Usage: /add-echo-tool <tool_name> (lowercase, numbers, underscores)\", \"warning\");\n\t\t\t\treturn;\n\t\t\t}\n\n\t\t\tconst created = registerEchoTool(too... [truncated]",
