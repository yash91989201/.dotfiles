  "script": "export const meta = { name: 'research_dynamic_workflows', description: 'Research pi-dynamic-workflows plugin: docs, examples, usage patterns', phases: [{ title: 'Research' }] }\n\nphase('Research')\n\nconst results = await parallel([\n  () => agent('Read plugin source and README from npm global install. Look in /home/yash/.bun/install/global/node_modules/@quintinshaw/pi-dynamic-workflows/ — read README.md, package.json, and any docs. Summarize: what it does, config options, key APIs, and how it integrates with pi.', { label: 'plugin source', tier: 'small' }),\n  () => agent('Search for examples and skills related to pi-dynamic-workflows in the pi ecosystem. Check /home/yash/.pi/agent/npm/node_modules/ and /home/yash/.bun/install/global/node_modules/@earendil-works/pi-coding-agent/ for references. Also check docs/ directories for workflow-related docs.', { label: 'ecosystem docs', tier: 'small' }),\n  () => agent('Read /home/yash/.pi/agent/npm/node_modules/pi-gitnexus/skills/ directory — look for any workflow-related skills or references to dynamic workflows. Also check /home/yash/.pi/agent/ for any config files that reference dynamic workflows.', { label: 'gitnexus and config', tier: 'small' })\n])\n\n// Synthesize\nconst synthesis = await agent(`You are synthesizing research about the @quintinshaw/pi-dynamic-workflows plugin for pi coding agent. Here are the research results:\n\n${JSON.stringify(results, null, 2)}\n\nCreate a comprehensive but concise guide covering:\n1. What the plugin does (core purpose)\n2. How to install and configure it\n3. Key concepts (workflow file format, phases, agent(), parallel(), pipeline())\n4. How to write effective workflows — patterns and anti-patterns\n5. Common use cases with examples\n6. Tips for efficient usage\n7. Any gotchas or limitations found\n\nBe thorough but practical. Include code examples where helpful.`, { label: 'synthesis', tier: 'big', schema: { type: 'object', properties: { summary: { type: 'string' }, guide: { type: 'string' }, examples: { type: 'string' }, tips: { type: 'string' }, gotchas: { type: 'string' } }, required: ['summary', 'guide'] } })\n\nreturn synthesis",
  "sessionId": "019f19a0-0286-7144-b2e4-6b6e2cee0a6f",
