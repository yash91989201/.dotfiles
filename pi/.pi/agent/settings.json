{
  "packages": [
    "npm:context-mode",
    "npm:pi-subagents",
    "npm:pi-morphllm-plugin",
    "npm:@juicesharp/rpiv-todo",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:pi-total-recall",
    "npm:pi-mcp-adapter",
    "npm:@juicesharp/rpiv-btw",
    "npm:pi-gitnexus",
    "npm:pi-caveman",
    "npm:pi-cursor-sdk",
    "npm:pi-powerline-footer",
    "npm:pi-web-access",
    "npm:@upstash/context7-pi"
  ],
  "skills": [
    "~/.agents/skills"
  ],
  "prompts": [
    "~/.pi/agent/prompts"
  ],
  "lastChangelogVersion": "0.79.3",
  "quietStartup": true,
  "theme": "tokyonight-night",
  "enableInstallTelemetry": false,
  "defaultProvider": "xiaomi",
  "defaultModel": "mimo-v2.5",
  "defaultThinkingLevel": "high",
  "enabledModels": [
    "xiaomi/mimo-v2.5",
    "xiaomi/mimo-v2.5-pro",
    "cursor/auto",
    "cursor/composer-latest:slow",
    "cursor/grok-build@1m",
    "cursor/gpt-5.3-codex",
    "cursor/sonnet-latest@1m",
    "cursor/grok-latest@1m",
    "cursor/opus-4.8@1m",
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4-mini",
    "fireworks/accounts/fireworks/models/minimax-m3",
    "fireworks/accounts/fireworks/routers/kimi-k2p6-turbo",
    "fireworks/accounts/fireworks/models/kimi-k2p7-code",
    "fireworks/accounts/fireworks/routers/kimi-k2p7-code-fast"
  ],
  "subagents": {
    "agentOverrides": {
      "oracle": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "high"
      },
      "researcher": {
        "model": "fireworks/accounts/fireworks/routers/kimi-k2p6-turbo",
        "thinking": "low"
      },
      "scout": {
        "model": "fireworks/accounts/fireworks/routers/kimi-k2p6-turbo",
        "thinking": "low"
      },
      "worker": {
        "model": "fireworks/accounts/fireworks/models/minimax-m3",
        "thinking": "low"
      },
      "reviewer": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium"
      }
    }
  },
  "warnings": {
    "anthropicExtraUsage": false
  },
  "treeFilterMode": "user-only",
  "powerline": "custom",
  "hideThinkingBlock": true,
  "editorPaddingX": 1,
  "terminal": {
    "showTerminalProgress": false,
    "imageWidthCells": 60
  },
  "collapseChangelog": true,
  "enableSkillCommands": true,
  "doubleEscapeAction": "tree",
  "httpIdleTimeoutMs": 300000,
  "autocompleteMaxVisible": 7,
  "defaultProjectTrust": "always"
}