{
  "settings": {
    "idleTimeout": 10,
    "toolPrefix": "server"
  },
  "mcpServers": {
    "context-mode": {
      "command": "context-mode",
      "lifecycle": "lazy",
      "directTools": [
        "ctx_search",
        "ctx_execute",
        "ctx_index",
        "ctx_stats"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "lifecycle": "lazy",
      "directTools": [
        "resolve-library-id",
        "query-docs"
      ]
    },
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "lifecycle": "lazy",
      "directTools": [
        "tavily_search"
      ]
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp@latest"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "lifecycle": "lazy",
      "directTools": [
        "firecrawl_scrape"
      ]
    }
  }
}
