{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-slim",
    "@morphllm/opencode-morph-plugin",
    "caveman-opencode-plugin",
    "context-mode",
    "@dietrichgebert/ponytail",
    "@mem0/opencode-plugin"
  ],
  "instructions": [
    "node_modules/@morphllm/opencode-morph-plugin/instructions/morph-tools.md"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true,
  "mcp": {
    "tavily": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "tavily-mcp@latest"
      ],
      "enabled": true
    },
    "firecrawl": {
      "type": "local",
      "command": [
        "firecrawl-mcp"
      ],
      "enabled": true
    }
  }
}
