          "websearch",
          "context7",
          "grep_app"
        ]
      },
      "explorer": {
        "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p6-turbo",
        "variant": "low",
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": "google/gemini-3.1-pro-preview",
        "variant": "medium",
        "skills": [
          "agent-browser"
        ],
        "mcps": []
      },
      "fixer": {
        "model": "fireworks-ai/accounts/fireworks/models/minimax-m2p7",
