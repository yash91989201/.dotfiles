{
  "$schema": "https://charm.land/crush.json",
  "lsp": {
    "dart": {
      "command": "/home/yashraj/development/flutter/bin/dart",
      "args": [
        "language-server",
        "--protocol=lsp"
      ],
      "env": {
        "PATH": "/home/yashraj/development/flutter/bin:/usr/bin:/bin"
      }
    },
    "go": {
      "command": "gopls",
      "env": {
        "GOTOOLCHAIN": "go1.25.3"
      }
    },
    "typescript": {
      "command": "typescript-language-server",
      "args": [
        "--stdio"
      ],
      "env": {
        "TSSERVER_PATH": "./node_modules/typescript/lib/tsserver.js"
      }
    }
  },
  "mcp": {
    "shadcn": {
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "command": "npx",
      "type": "stdio"
    },
    "context7": {
      "command": "npx",
      "type": "stdio",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "tavily": {
      "type": "stdio",
      "args": [
        "-y",
        "tavily-mcp"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "command": "npx"
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "browsermcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@browsermcp/mcp@latest"
      ]
    },
    "grep": {
      "url": "https://mcp.grep.app",
      "type": "http"
    }
  }
}
